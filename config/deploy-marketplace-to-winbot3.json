{
  "agent_name": "ai-deploy",
  "description": "Deploy Marketplace scripts to winbot3",
  "application_name": "agencyos",
  "source": {
    "type": "windows_share",
    "path": "C:\\git\\{{APPLICATION_NAME}}\\scripts\\marketplace"
  },
  "destination": {
    "type": "windows_share",
    "path": "\\\\winbot3\\share\\marketplace\\src"
  },
  "website": {
    "path": "\\\\winbot3\\share\\marketplace\\src",
    "ignore": {
      "files": [".gitignore", ".DS_Store", "Thumbs.db", "desktop.ini"],
      "folders": [".git", ".vscode", ".idea"],
      "extensions": [".md", ".log", ".tmp", ".bak", ".backup", ".old", ".orig"]
    }
  },
  "options": {
    "verbose": false,
    "dry_run": false,
    "delete_extra_files": true,
    "ignore_cache": true,
    "clean_install": false
  }
}
